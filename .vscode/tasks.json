{
  "version": "2.0.0",
  "tasks": [
    {
      "label": "Setup Local Environment",
      "type": "shell",
      "command": "setup.bat",
      "args": ["install"],
      "options": {
        "shell": {
          "executable": "C:\\Windows\\System32\\cmd.exe",
          "args": ["/d", "/c"]
        }
      },
      "isBackground": false,
      "group": {
        "kind": "build",
        "isDefault": true
      },
      "presentation": {
        "reveal": "always",
        "panel": "shared",
        "clear": true
      }
    },
    {
      "label": "Start Development Server",
      "type": "shell",
      "command": "setup.bat",
      "args": ["dev"],
      "options": {
        "shell": {
          "executable": "C:\\Windows\\System32\\cmd.exe",
          "args": ["/d", "/c"]
        }
      },
      "isBackground": true,
      "presentation": {
        "reveal": "always",
        "panel": "dedicated",
        "clear": true
      },
      "problemMatcher": {
        "owner": "custom",
        "pattern": {
          "regexp": "^(.*)$",
          "message": 1
        },
        "background": {
          "activeOnStart": true,
          "beginsPattern": "^\\s*VITE\\s+v",
          "endsPattern": "^\\s*.*Local:\\s+http://localhost:[0-9]+/pages/"
        }
      }
    },
    {
      "label": "Build for Production",
      "type": "shell",
      "command": "setup.bat",
      "args": ["build"],
      "options": {
        "shell": {
          "executable": "C:\\Windows\\System32\\cmd.exe",
          "args": ["/d", "/c"]
        }
      },
      "group": "build",
      "presentation": {
        "reveal": "always",
        "panel": "shared",
        "clear": true
      }
    },
    {
      "label": "Preview Production Build",
      "type": "shell",
      "command": "setup.bat",
      "args": ["preview"],
      "options": {
        "shell": {
          "executable": "C:\\Windows\\System32\\cmd.exe",
          "args": ["/d", "/c"]
        }
      },
      "isBackground": true,
      "dependsOn": "Build for Production",
      "presentation": {
        "reveal": "always",
        "panel": "dedicated",
        "clear": true
      },
      "problemMatcher": {
        "owner": "custom",
        "pattern": {
          "regexp": "^(.*)$",
          "message": 1
        },
        "background": {
          "activeOnStart": true,
          "beginsPattern": "^\\s*>\\s+vite\\s+preview$",
          "endsPattern": "^\\s*.*Local:\\s+http://localhost:[0-9]+/pages/"
        }
      }
    }
  ]
}
